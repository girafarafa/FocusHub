{
  "name": "focushub",
  "version": "1.0.0",
  "description": "Your persistent productivity workspace",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.anastasia.focushub",
    "productName": "FocusHub",
    "win": {
      "target": "portable",
      "executableName": "FocusHub"
    },
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}